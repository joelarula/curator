{
  "manifest_version": 3,
  "name": "Curator Knowledge Studio",
  "version": "1.0.0",
  "description": "Your semantic client-side knowledge graph inside Chrome",
  "permissions": ["activeTab", "tabs", "storage", "unlimitedStorage", "contextMenus", "notifications"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "src/popup/icon16.png",
    "48": "src/popup/icon48.png",
    "128": "src/popup/icon128.png"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Curator Studio",
    "default_icon": {
      "16": "src/popup/icon16.png",
      "48": "src/popup/icon48.png",
      "128": "src/popup/icon128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
