{
  "name": "curator-chrome-extension",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build && node esbuild.config.js",
    "build:popup": "vite build",
    "build:bg": "node esbuild.config.js",
    "watch": "concurrently \"vite build --watch\" \"node esbuild.config.js --watch\"",
    "prisma:generate-wasm": "set PRISMA_CLIENT_ENGINE_TYPE=wasm && prisma generate --schema=../server/prisma/schema/base.prisma",
    "postinstall": "prisma generate --schema=../server/prisma/schema/base.prisma"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.33",
    "@mdi/font": "^7.4.47",
    "@prisma/client": "^7.6.0",
    "graphql": "^16.12.0",
    "path-browserify": "^1.0.1",
    "sql.js": "^1.14.1",
    "vue": "^3.5.35",
    "vuetify": "^4.0.8"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^10.0.3",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.2",
    "vite": "^6.4.2",
    "vite-plugin-vuetify": "^2.1.3"
  }
}
