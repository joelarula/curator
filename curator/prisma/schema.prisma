datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────────────────────────────────────
// Conversation — groups Requests and Responses for a single user interaction
// Replaces the old ADK session/event tables
// ─────────────────────────────────────────────────────────────────────────────

model Conversation {
  id          String     @id @default(uuid())
  userId      Int
  user        User       @relation(fields: [userId], references: [id])
  state       Json?
  requests    Request[]
  responses   Response[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Minimal Curator Workflow Models
// ─────────────────────────────────────────────────────────────────────────────

model Tool {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  description      String
  parametersSchema Json?
  sourceCode       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Agent {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  projectId   Int?
  project     Project? @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  workflows   AgentWorkflow[]
}

model AgentWorkflow {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  ast         Json?
  sourceCode  String?
  
  agentId     Int
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  eventSubscriptions EventSubscription[]
  scheduledAgents    ScheduledAgent[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EventSubscription {
  id               Int      @id @default(autoincrement())
  eventName        String
  
  agentWorkflowId  Int?
  agentWorkflow    AgentWorkflow? @relation(fields: [agentWorkflowId], references: [id])
  
  workflowAst      Json?
  
  userId           Int
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId        Int?
  project          Project? @relation(fields: [projectId], references: [id])
  
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  @@index([eventName, isActive])
}


model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique
  name          String?
  email         String?        @unique
  requests      Request[]
  resources     Resource[]
  projects      Project[]
  scheduledAgents ScheduledAgent[]
  conversations Conversation[]
  agents        Agent[]
  eventSubscriptions EventSubscription[]
  createdAt     DateTime       @default(now())
}

model Request {
  id                  Int           @id @default(autoincrement())
  status              String        @default("NEW")
  toolName            String?
  userId              Int
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId           Int?
  project             Project?      @relation(fields: [projectId], references: [id])
  conversationId      String
  conversation        Conversation  @relation(fields: [conversationId], references: [id])
  ast                 Json?
  context             Json?
  priority            Int           @default(0) // Higher = more urgent. Interrupts use high values.
  lockedBy            String?
  lockedAt            DateTime?
  scheduledAt         DateTime?
  retryCount          Int           @default(0)
  notifyId            Int?          // ID of the parent/join Request to wake up on completion
  pendingDependencies Int           @default(0) // If >0 this Request is blocked
  responses           Response[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Response {
  id             Int          @id @default(autoincrement())
  requestId      Int
  request        Request      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  projectId      Int?
  project        Project?     @relation(fields: [projectId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  userId         Int
  content        String
  createdAt      DateTime     @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// RDF Graph Triplestore Models
// ─────────────────────────────────────────────────────────────────────────────

model Resource {
  id                 Int               @id @default(autoincrement())
  uri                String            @unique
  title              String?
  description        String?
  content            String?
  
  userId             Int
  user               User              @relation(fields: [userId], references: [id])
  projectId          Int?
  project            Project?          @relation(fields: [projectId], references: [id])
  
  subjectRelations   Relation[]        @relation("RelationSubject")
  predicateRelations Relation[]        @relation("RelationPredicate")
  objectRelations    Relation[]        @relation("RelationObject")
  attachments        Attachment[]
  
  existent           Boolean?          @default(true)
  deletedAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([uri, existent])
}

model Relation {
  id             Int          @id @default(autoincrement())
  subjectId      Int
  predicateId    Int
  objectId       Int
  subject        Resource     @relation("RelationSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  predicate      Resource     @relation("RelationPredicate", fields: [predicateId], references: [id], onDelete: Cascade)
  object         Resource     @relation("RelationObject", fields: [objectId], references: [id], onDelete: Cascade)
  
  literalValue     Float?
  literalDate      DateTime?
  literalBoolean   Boolean?
  literalDatatypeId Int?
  literalDatatype   Datatype? @relation(fields: [literalDatatypeId], references: [id])

  projectId        Int?
  project          Project? @relation(fields: [projectId], references: [id])
  existent         Boolean? @default(true)
  createdAt        DateTime @default(now())

  @@unique([subjectId, predicateId, objectId])
  @@index([subjectId, existent])
  @@index([predicateId, existent])
  @@index([objectId, existent])
}

model Datatype {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  relations Relation[]
}

model Attachment {
  id         String    @id @default(cuid())
  resourceId Int?
  resource   Resource? @relation(fields: [resourceId], references: [id])
  uri        String    @unique
  filename   String
  mimetype   String
  url        String
  size       Int
  existent   Boolean?  @default(true)
  createdAt  DateTime  @default(now())

  @@index([existent])
}

model Project {
  id          Int       @id @default(autoincrement())
  name        String
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  
  resources   Resource[]
  relations   Relation[]
  requests    Request[]
  responses   Response[]
  scheduledAgents ScheduledAgent[]
  agents      Agent[]
  eventSubscriptions EventSubscription[]

  existent    Boolean?  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, existent])
}

model ScheduledAgent {
  id          Int      @id @default(autoincrement())
  // 'system' is a reserved name and should be blocked at the application level
  name        String   
  description String?
  
  // Execution type (mutually exclusive)
  scriptPath  String?  // Relative path to filesystem built-in script
  workflowName String? // Name of the agent workflow in the database
  workflow    AgentWorkflow? @relation(fields: [workflowName], references: [name])
  workflowParams Json? // Serialized parameters for the workflow execution
  
  schedule    String?  // Cron/Bree recurring syntax (e.g., "every 15 minutes", "* * * * *"). Null if runOnce=true.
  runOnce     Boolean  @default(false) // If true, runs exactly once at runAt time then deactivates
  runAt       DateTime? // UTC datetime to run once. Required if runOnce=true.
  isActive    Boolean  @default(true)
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   Int?
  project     Project? @relation(fields: [projectId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, name])
}
