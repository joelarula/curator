// ─────────────────────────────────────────────────────────────────────────────
// Curator — SQLite Schema
// Used exclusively by the `curator run --db <name>` CLI path.
// • provider: sqlite (no pgvector, no @db.* type modifiers)
// • Actor / auth models omitted — replaced by a minimal User stub
// • Lives in prisma/sqlite/ to be fully isolated from the PG schema in
//   prisma/schema/ — preventing Prisma LS from seeing duplicate model names
// • Generates to ../../src/generated/prisma-sqlite/
// ─────────────────────────────────────────────────────────────────────────────

generator sqliteClient {
  provider        = "prisma-client-js"
  output          = "../../src/generated/prisma-sqlite"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────────────────────────────────────
// Minimal User stub — enough for the CLI to resolve a user and create
// requests/conversations. No auth, no OAuth, no sessions.
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  requests  Request[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Core models (mirrors prisma/schema/core.prisma with PG-specific types removed)
// ─────────────────────────────────────────────────────────────────────────────

enum RequestStatus {
  NEW
  WAITING
  COMPLETED
  FAILED
}

model Project {
  id            String         @id @default(cuid())
  name          String
  userId        String
  resources     Resource[]
  relations     Relation[]
  scripts       Script[]
  agents        Agent[]
  requests      Request[]
  conversations Conversation[]
  responses     Response[]
  resourceTrees ResourceTree[]
  existent      Boolean?       @default(true)
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId, existent])
}

model Tool {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  version     String?
  enabled     Boolean  @default(true)
  existent    Boolean? @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([existent])
}

model Resource {
  id                 Int            @id @default(autoincrement())
  uri                String
  title              String?
  description        String?
  isPublished        Boolean        @default(false)
  userId             String
  projectId          String?
  project            Project?       @relation(fields: [projectId], references: [id])
  metadata           Json?
  existent           Boolean?       @default(true)
  deletedAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  requests           Request[]      @relation("RequestResources")
  conversations      Conversation[] @relation("ConversationResources")
  texts              Text[]         @relation("ResourceTexts")
  subjectRelations   Relation[]     @relation("RelationSubject")
  predicateRelations Relation[]     @relation("RelationPredicate")
  objectRelations    Relation[]     @relation("RelationObject")
  treeNodes          ResourceTree[]
  attachments        Attachment[]

  @@unique([uri])
  @@unique([id, existent])
  @@index([uri, existent])
  @@index([existent])
  @@index([deletedAt])
  @@index([projectId])
}

model Text {
  resourceId  Int?
  resource    Resource? @relation("ResourceTexts", fields: [resourceId], references: [id])
  id          String    @id @default(cuid())
  content     String
  role        String    @default("MAIN")
  mimeType    String?   @default("text/plain")
  extension   String?   @default("txt")
  isPublished Boolean   @default(false)
  existent    Boolean?  @default(true)
  deletedAt   DateTime?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([resourceId, existent])
  @@index([existent])
  @@unique([resourceId, role])
}

model Relation {
  id              Int       @id @default(autoincrement())
  subjectId       Int
  predicateId     Int
  objectId        Int
  subject         Resource  @relation("RelationSubject",   fields: [subjectId],   references: [id], onDelete: Cascade)
  predicate       Resource  @relation("RelationPredicate", fields: [predicateId], references: [id], onDelete: Cascade)
  object          Resource  @relation("RelationObject",    fields: [objectId],    references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  aiModelId       Int?
  aiModel         AIModel?  @relation(fields: [aiModelId], references: [id])
  literalValue    Float?
  literalString   String?
  literalDate     DateTime?
  literalBoolean  Boolean?
  literalDatatype String?
  selectionStart  Int?
  selectionEnd    Int?
  justification   String?
  projectId       String?
  project         Project?  @relation(fields: [projectId], references: [id])
  existent        Boolean?  @default(true)

  @@unique([subjectId, predicateId, objectId])
  @@index([subjectId, existent])
  @@index([predicateId, existent])
  @@index([objectId, existent])
  @@index([existent])
  @@index([projectId])
}

model Attachment {
  resourceId Int?
  resource   Resource? @relation(fields: [resourceId], references: [id])
  id         String    @id @default(cuid())
  uri        String    @unique
  filename   String
  mimetype   String
  url        String
  size       Int
  existent   Boolean?  @default(true)
  createdAt  DateTime  @default(now())

  @@index([existent])
}

model AIModel {
  id        Int        @id @default(autoincrement())
  shortName String     @unique
  name      String     @unique
  provider  String
  type      String
  version   String?
  url       String?
  requests  Request[]
  responses Response[]
  relations Relation[]
  deletedAt DateTime?
  existent  Boolean?   @default(true)
  createdAt DateTime   @default(now())

  @@index([existent])
}

model Script {
  id        Int       @id @default(autoincrement())
  name      String
  body      String?
  toolCalls Json?
  ast       Json?
  userId    String?
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id])
  requests  Request[]
  agents    Agent[]
  existent  Boolean?  @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([existent])
  @@unique([name])
}

model Request {
  id                 Int           @id @default(autoincrement())
  status             RequestStatus @default(NEW)
  toolName           String?
  retryCount         Int           @default(0)
  scriptId           Int?
  script             Script?       @relation(fields: [scriptId], references: [id])
  aiModelId          Int?
  aiModel            AIModel?      @relation(fields: [aiModelId], references: [id])
  userId             String
  user               User          @relation(fields: [userId], references: [id])
  projectId          String?
  project            Project?      @relation(fields: [projectId], references: [id])
  ast                Json?
  context            Json?
  resources          Resource[]    @relation("RequestResources")
  conversationId     Int
  conversation       Conversation  @relation(fields: [conversationId], references: [id])
  agentId            String?
  agent              Agent?        @relation(fields: [agentId], references: [id])
  scheduledAt        DateTime      @default(now())
  executionScheduled DateTime?     @default(now())
  lockedBy           String?
  lockedAt           DateTime?
  deletedAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  responses          Response[]
  parentId           Int?
  parent             Request?      @relation("Workflow", fields: [parentId], references: [id])
  children           Request[]     @relation("Workflow")
  existent           Boolean?      @default(true)

  @@index([status, existent])
  @@index([existent])
}

model Response {
  id             Int          @id @default(autoincrement())
  requestId      Int
  request        Request      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  content        String
  aiModelId      Int?
  aiModel        AIModel?     @relation(fields: [aiModelId], references: [id])
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  existent       Boolean?     @default(true)
  createdAt      DateTime     @default(now())

  @@index([existent])
}

model Conversation {
  id         Int        @id @default(autoincrement())
  externalId String     @unique @default(cuid())
  userId     String
  projectId  String?
  project    Project?   @relation(fields: [projectId], references: [id])
  requests   Request[]
  responses  Response[]
  resources  Resource[] @relation("ConversationResources")
  metadata   Json?
  existent   Boolean?   @default(true)
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  workflowSession WorkflowSession?
  
  @@index([existent])
}

model ResourceTree {
  id         Int            @id @default(autoincrement())
  treeName   String
  resourceId Int
  resource   Resource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  parentId   Int?
  parent     ResourceTree?  @relation("TreeHierarchy", fields: [parentId], references: [id])
  children   ResourceTree[] @relation("TreeHierarchy")
  treeStart  Float
  treeEnd    Float
  depth      Int            @default(0)
  projectId  String?
  project    Project?       @relation(fields: [projectId], references: [id])
  deletedAt  DateTime?
  existent   Boolean?       @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([treeName, resourceId])
  @@index([treeName, treeStart, treeEnd, existent])
  @@index([existent])
  @@index([deletedAt])
}

model Agent {
  id           String    @id @default(cuid())
  name         String
  scriptId     Int
  script       Script    @relation(fields: [scriptId], references: [id])
  schedule     String    @default("every 10 minutes")
  lastPolledAt DateTime?
  userId       String
  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id])
  enabled      Boolean   @default(true)
  existent     Boolean?  @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  requests     Request[]

  @@unique([name])
  @@index([existent])
}

model Task {
  id             String          @id @default(cuid())
  workflowName   String
  status         String          @default("PENDING")
  inputData      Json
  outputData     Json?
  
  sessionId      String?
  session        WorkflowSession? @relation(fields: [sessionId], references: [id])
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model WorkflowSession {
  id             String               @id @default(cuid())
  conversationId Int                  @unique
  conversation   Conversation         @relation(fields: [conversationId], references: [id])
  
  state          Json
  checkpoints    WorkflowCheckpoint[]
  tasks          Task[]
  
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model WorkflowCheckpoint {
  id           String          @id @default(cuid())
  sessionId    String
  session      WorkflowSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  nodeId       String
  status       String
  result       Json?
  createdAt    DateTime        @default(now())
}

