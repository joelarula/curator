enum RequestStatus {
  NEW
  WAITING
  COMPLETED
  FAILED
}

model ResourceType {
  id        Int        @id @default(autoincrement())
  name      String     @unique // e.g. "ENTITY", "PROPERTY", "CLASS"
  resources Resource[]
  relations Relation[]
}

model ResourceStatus {
  id        Int        @id @default(autoincrement())
  name      String     @unique // e.g. "NEW", "ACTIVE", "ARCHIVED"
  resources Resource[]
}

model TextRole {
  id    Int    @id @default(autoincrement())
  name  String @unique // e.g. "MAIN", "SUMMARY", "TRANSCRIPT"
  texts Text[]
}

model Resource {
  id                 Int             @id @default(autoincrement())
  uri                String          @unique
  title              String?         @db.VarChar(255)
  description        String?         @db.Text
  isPublished        Boolean         @default(false)
  statusId           Int?
  status             ResourceStatus? @relation(fields: [statusId], references: [id])
  resourceTypeId     Int?
  resourceType       ResourceType?   @relation(fields: [resourceTypeId], references: [id])
  userId             String
  user               User            @relation(fields: [userId], references: [id])
  prompts            Prompt[]        @relation("PromptResources")
  texts              Text[]          @relation("ResourceTexts")
  subjectRelations   Relation[]      @relation("RelationSubject")
  predicateRelations Relation[]      @relation("RelationPredicate")
  objectRelations    Relation[]      @relation("RelationObject")
  attachments        Attachment[]
  existent           Boolean?        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([existent])
}

model Text {
  resourceId  Int?
  resource    Resource? @relation("ResourceTexts", fields: [resourceId], references: [id])
  id          String    @id @default(cuid())
  content     String    @db.Text
  roleId      Int
  role        TextRole  @relation(fields: [roleId], references: [id])
  isPublished Boolean   @default(false)
  existent    Boolean?  @default(true)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([resourceId])
}

model Relation {
  id               Int       @id @default(autoincrement())
  resourceTypeId   Int
  resourceType     ResourceType @relation(fields: [resourceTypeId], references: [id])
  subjectId        Int
  predicateId      Int
  objectId         Int
  subject          Resource  @relation("RelationSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  predicate        Resource  @relation("RelationPredicate", fields: [predicateId], references: [id], onDelete: Cascade)
  object           Resource  @relation("RelationObject", fields: [objectId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  responseId       Int?
  response         Response? @relation(fields: [responseId], references: [id])

  literalValue   Float?
  selectionStart Int?
  selectionEnd   Int?

  justification String?

  @@unique([subjectId, predicateId, objectId])
  @@index([subjectId])
  @@index([predicateId])
  @@index([objectId])
}

model Attachment {
  resourceId Int?
  resource   Resource? @relation(fields: [resourceId], references: [id])
  id         String    @id @default(cuid())
  uri        String    @unique
  filename   String
  mimetype   String
  url        String
  size       Int
  existent   Boolean?  @default(true)
  createdAt  DateTime  @default(now())
}

model AIModel {
  id       String  @id @default(cuid())
  uri      String  @unique
  name     String  @unique
  provider String
  version  String?

  prompts Prompt[]

  existent  Boolean? @default(true)
  createdAt DateTime @default(now())
}

model PromptTemplate {
  id        String   @id @default(cuid())
  name      String
  prompt    String?  @db.Text
  toolCalls Json?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompts   Prompt[]
  agents    Agent[]
  existent  Boolean? @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, name])
}

model Prompt {
  id         Int            @id @default(autoincrement())
  uri        String         @unique
  templateId String
  template   PromptTemplate @relation(fields: [templateId], references: [id])
  requests   Request[]
  aiModelId  String?
  aiModel    AIModel?       @relation(fields: [aiModelId], references: [id])
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt     String?        @db.Text
  toolCalls  Json?
  existent   Boolean?       @default(true)
  createdAt  DateTime       @default(now())
  resources  Resource[]     @relation("PromptResources")
}

model Request {
  id             Int           @id @default(autoincrement())
  status         RequestStatus @default(NEW)
  retryCount     Int           @default(0)
  promptId       Int?
  prompt         Prompt?       @relation(fields: [promptId], references: [id])
  conversationId Int
  conversation   Conversation  @relation(fields: [conversationId], references: [id])
  scheduledAt    DateTime      @default(now())
  lockedBy       String?
  lockedAt       DateTime?
  existent       Boolean?      @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  responses      Response[]

  // Workflow tracking
  parentId       Int?
  parent         Request?      @relation("Workflow", fields: [parentId], references: [id])
  children       Request[]     @relation("Workflow")
}

model Response {
  relations      Relation[]
  id             Int          @id @default(autoincrement())
  requestId      Int
  request        Request      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  content        String       @db.Text
  toolCalls      Json?
  createdAt      DateTime     @default(now())
}

model Conversation {
  id        Int        @id @default(autoincrement())
  requests  Request[]
  responses Response[]
  existent  Boolean?   @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Agent {
  id             String    @id @default(cuid())
  name           String
  templateId     String
  template       PromptTemplate @relation(fields: [templateId], references: [id])
  schedule       String    @default("every 10 minutes")
  lastPolledAt   DateTime?
  userId         String
  user           User      @relation(fields: [userId], references: [id])

  enabled   Boolean  @default(true)
  existent  Boolean? @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}
