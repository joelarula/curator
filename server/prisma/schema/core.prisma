enum RequestStatus {
  NEW
  WAITING
  COMPLETED
  FAILED
}

model Tool {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g. "upsert_resource", "categorize_article"
  description String?  @db.Text
  version     String? // semver, e.g. "1.0.0"
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model ResourceType {
  id        Int        @id @default(autoincrement())
  name      String     @unique // e.g. "ENTITY", "PROPERTY", "CLASS"
  resources Resource[]
  relations Relation[]
}

model ResourceStatus {
  id        Int        @id @default(autoincrement())
  name      String     @unique // e.g. "NEW", "ACTIVE", "ARCHIVED"
  resources Resource[]
}

model TextRole {
  id    Int    @id @default(autoincrement())
  name  String @unique // e.g. "MAIN", "SUMMARY", "TRANSCRIPT"
  texts Text[]
}

model Language {
  id        Int        @id @default(autoincrement())
  code      String     @unique // BCP 47, e.g. "et", "en", "de"
  name      String     @unique // e.g. "Estonian", "English"
  texts     Text[]
  relations Relation[]
  resources Resource[]
}

model Resource {
  id                 Int               @id @default(autoincrement())
  uri                String            @unique
  title              String?           @db.VarChar(255)
  notation           String?           @db.VarChar(50)
  description        String?           @db.Text
  isPublished        Boolean           @default(false)
  statusId           Int?
  status             ResourceStatus?   @relation(fields: [statusId], references: [id])
  resourceTypeId     Int?
  resourceType       ResourceType?     @relation(fields: [resourceTypeId], references: [id])
  languageId         Int?
  language           Language?         @relation(fields: [languageId], references: [id])
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  requests           Request[]         @relation("RequestResources")
  conversations      Conversation[]    @relation("ConversationResources")
  texts              Text[]            @relation("ResourceTexts")
  subjectRelations   Relation[]        @relation("RelationSubject")
  predicateRelations Relation[]        @relation("RelationPredicate")
  objectRelations    Relation[]        @relation("RelationObject")
  treeNodes          ResourceTree[]
  attachments        Attachment[]
  existent           Boolean?          @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([existent])
  @@index([notation])
}

model Text {
  resourceId  Int?
  resource    Resource? @relation("ResourceTexts", fields: [resourceId], references: [id])
  id          String    @id @default(cuid())
  content     String    @db.Text
  roleId      Int
  role        TextRole  @relation(fields: [roleId], references: [id])
  languageId  Int?
  language    Language? @relation(fields: [languageId], references: [id])
  isPublished Boolean   @default(false)
  existent    Boolean?  @default(true)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([resourceId])
  @@index([languageId])
  @@unique([resourceId, roleId])
}

model Relation {
  id             Int          @id @default(autoincrement())
  resourceTypeId Int
  resourceType   ResourceType @relation(fields: [resourceTypeId], references: [id])
  subjectId      Int
  predicateId    Int
  objectId       Int
  subject        Resource     @relation("RelationSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  predicate      Resource     @relation("RelationPredicate", fields: [predicateId], references: [id], onDelete: Cascade)
  object         Resource     @relation("RelationObject", fields: [objectId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  responseId     Int?
  response       Response?    @relation(fields: [responseId], references: [id])
  aiModelId      Int?
  aiModel        AIModel?     @relation(fields: [aiModelId], references: [id])

  literalValue   Float?
  selectionStart Int?
  selectionEnd   Int?

  justification String?

  languageId Int?
  language   Language? @relation(fields: [languageId], references: [id])

  @@unique([subjectId, predicateId, objectId])
  @@index([subjectId])
  @@index([predicateId])
  @@index([objectId])
}

model Attachment {
  resourceId Int?
  resource   Resource? @relation(fields: [resourceId], references: [id])
  id         String    @id @default(cuid())
  uri        String    @unique
  filename   String
  mimetype   String
  url        String
  size       Int
  existent   Boolean?  @default(true)
  createdAt  DateTime  @default(now())
}

model AIModel {
  id        Int     @id @default(autoincrement())
  shortName String  @unique // e.g. "distilbert", "gpt-4"
  name      String  @unique // e.g. "Xenova/distilbert-base-uncased-mnli"
  provider  String // e.g. "HuggingFace", "OpenAI"
  type      String // e.g. "GENERATIVE", "EMBEDDING"
  version   String?
  url       String?

  requests  Request[]
  responses Response[]
  relations Relation[]

  existent  Boolean? @default(true)
  createdAt DateTime @default(now())
}

model Script {
  id        Int       @id @default(autoincrement())
  name      String
  body      String?   @db.Text // The dynamic logic (JS)
  toolCalls Json? // The static/compiled logic
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests  Request[]
  agents    Agent[]
  existent  Boolean?  @default(true)
  createdAt DateTime  @default(now())

  @@unique([name])
}

model Request {
  id         Int           @id @default(autoincrement())
  status     RequestStatus @default(NEW)
  toolName   String?
  retryCount Int           @default(0)

  scriptId  Int?
  script    Script?    @relation(fields: [scriptId], references: [id])
  aiModelId Int?
  aiModel   AIModel?   @relation(fields: [aiModelId], references: [id])
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolCalls Json?
  toolArgs  Json?
  callbacks Json?
  resources Resource[] @relation("RequestResources")

  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  scheduledAt    DateTime     @default(now())
  lockedBy       String?
  lockedAt       DateTime?
  existent       Boolean?     @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  responses      Response[]

  // Workflow tracking
  parentId Int?
  parent   Request?  @relation("Workflow", fields: [parentId], references: [id])
  children Request[] @relation("Workflow")
}

model Response {
  relations      Relation[]
  id             Int          @id @default(autoincrement())
  requestId      Int
  request        Request      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  content        String       @db.Text
  toolCalls      Json?
  aiModelId      Int?
  aiModel        AIModel?     @relation(fields: [aiModelId], references: [id])
  createdAt      DateTime     @default(now())
}

model Conversation {
  id         Int        @id @default(autoincrement())
  externalId String     @unique @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id])
  requests   Request[]
  responses  Response[]
  resources  Resource[] @relation("ConversationResources")
  metadata   Json?
  existent   Boolean?   @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model ResourceTree {
  id         Int      @id @default(autoincrement())
  treeName   String   @db.VarChar(100)
  resourceId Int
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  
  parentId   Int?
  parent     ResourceTree?  @relation("TreeHierarchy", fields: [parentId], references: [id])
  children   ResourceTree[] @relation("TreeHierarchy")

  treeStart  Float
  treeEnd    Float
  depth      Int      @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([treeName, resourceId])
  @@index([treeName, treeStart, treeEnd])
}

model UdcLookup {
  id         Int      @id @default(autoincrement())
  notation   String   @unique @db.VarChar(50)
  uri        String   @unique
  title      String   @db.VarChar(255)
  enLabel    String?  @db.VarChar(255)
  etLabel    String?  @db.VarChar(255)
  parentUri  String?  @db.VarChar(255)
  treeStart  Float
  treeEnd    Float
  depth      Int
  
  createdAt  DateTime @default(now())
}

model Agent {
  id           String    @id @default(cuid())
  name         String
  scriptId     Int
  script       Script    @relation(fields: [scriptId], references: [id])
  schedule     String    @default("every 10 minutes")
  lastPolledAt DateTime?
  userId       String
  user         User      @relation(fields: [userId], references: [id])

  enabled   Boolean  @default(true)
  existent  Boolean? @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
}
