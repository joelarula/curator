enum RequestStatus {
  NEW
  WAITING
  COMPLETED
  FAILED
}

model Project {
  id          String    @id @default(cuid())
  name        String
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  
  resources   Resource[]
  relations   Relation[]
  scripts     Script[]
  agents      Agent[]
  requests    Request[]
  conversations Conversation[]
  responses   Response[]
  resourceTrees ResourceTree[]




  existent    Boolean?  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, existent])
}


model Tool {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g. "upsert_resource", "categorize_article"
  description String?  @db.Text
  version     String? // semver, e.g. "1.0.0"
  enabled     Boolean  @default(true)
  existent    Boolean? @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([existent])
}









model Resource {
  id                 Int               @id @default(autoincrement())
  uri                String            
  title              String?           @db.VarChar(255)
  description        String?           @db.Text
  isPublished        Boolean           @default(false)
  
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  
  projectId          String?
  project            Project?          @relation(fields: [projectId], references: [id])

  metadata           Json?             // Extensible storage for external IDs, AI confidence, etc.
  
  existent           Boolean?          @default(true)
  deletedAt          DateTime?         // Soft delete timestamp
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt


  requests           Request[]         @relation("RequestResources")
  conversations      Conversation[]    @relation("ConversationResources")
  texts              Text[]            @relation("ResourceTexts")
  subjectRelations   Relation[]        @relation("RelationSubject")
  predicateRelations Relation[]        @relation("RelationPredicate")
  objectRelations    Relation[]        @relation("RelationObject")
  treeNodes          ResourceTree[]
  attachments        Attachment[]

  @@unique([uri])                       // Studio-wide URI identity
  @@index([uri, existent])
  @@index([existent])
  @@index([deletedAt])
  @@index([projectId])

}




model Text {
  resourceId  Int?
  resource    Resource? @relation("ResourceTexts", fields: [resourceId], references: [id])
  id          String    @id @default(cuid())
  content     String    @db.Text
  role        String    @default("MAIN")

  
  isPublished Boolean   @default(false)
  existent    Boolean?  @default(true)
  deletedAt   DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([resourceId, existent])
  @@index([existent])
  @@unique([resourceId, role])


}


model Relation {
  id             Int          @id @default(autoincrement())
  subjectId      Int
  predicateId    Int
  objectId       Int
  subject        Resource     @relation("RelationSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  predicate      Resource     @relation("RelationPredicate", fields: [predicateId], references: [id], onDelete: Cascade)
  object         Resource     @relation("RelationObject", fields: [objectId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  aiModelId      Int?
  aiModel        AIModel?     @relation(fields: [aiModelId], references: [id])


  
  literalValue     Float?
  literalString    String?   @db.Text
  literalDate      DateTime?
  literalBoolean   Boolean?
  literalDatatype  String?   // RDF Datatype URI (e.g. xsd:string)

  selectionStart Int?
  selectionEnd   Int?


  justification String?

  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id])

  existent      Boolean? @default(true)

  @@unique([subjectId, predicateId, objectId])
  @@index([subjectId, existent])
  @@index([predicateId, existent])
  @@index([objectId, existent])
  @@index([existent])
  @@index([projectId])

}



model Attachment {
  resourceId Int?
  resource   Resource? @relation(fields: [resourceId], references: [id])
  id         String    @id @default(cuid())
  uri        String    @unique
  filename   String
  mimetype   String
  url        String
  size       Int
  existent   Boolean?  @default(true)
  createdAt  DateTime  @default(now())

  @@index([existent])
}


model AIModel {
  id        Int     @id @default(autoincrement())
  shortName String  @unique // e.g. "distilbert", "gpt-4"
  name      String  @unique // e.g. "Xenova/distilbert-base-uncased-mnli"
  provider  String // e.g. "HuggingFace", "OpenAI"
  type      String // e.g. "GENERATIVE", "EMBEDDING"
  version   String?
  url       String?

  requests  Request[]
  responses Response[]
  relations Relation[]



  deletedAt DateTime?
  existent  Boolean? @default(true)
  createdAt DateTime @default(now())

  @@index([existent])
}



model Script {
  id        Int       @id @default(autoincrement())
  name      String
  body      String?   @db.Text // The dynamic logic (JS)
  toolCalls Json? // The static/compiled logic
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id])

  requests  Request[]
  agents    Agent[]
  existent  Boolean? @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())


  @@index([existent])



  @@unique([name])
}

model Request {
  id         Int           @id @default(autoincrement())
  status     RequestStatus @default(NEW)
  toolName   String?
  retryCount Int           @default(0)

  scriptId  Int?
  script    Script?    @relation(fields: [scriptId], references: [id])
  aiModelId Int?
  aiModel   AIModel?   @relation(fields: [aiModelId], references: [id])
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  projectId String?
  project   Project?   @relation(fields: [projectId], references: [id])

  toolCalls Json?
  toolArgs  Json?
  callbacks Json?

  resources Resource[] @relation("RequestResources")

  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  scheduledAt    DateTime     @default(now())
  lockedBy       String?
  lockedAt       DateTime?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses      Response[]

  // Workflow tracking
  parentId Int?
  parent   Request?  @relation("Workflow", fields: [parentId], references: [id])
  children Request[] @relation("Workflow")

  existent Boolean? @default(true)

  @@index([status, existent])
  @@index([existent])
}


model Response {

  id             Int          @id @default(autoincrement())
  requestId      Int
  request        Request      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  content        String       @db.Text
  toolCalls      Json?
  aiModelId      Int?
  aiModel        AIModel?     @relation(fields: [aiModelId], references: [id])

  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])

  existent       Boolean?     @default(true)

  createdAt      DateTime     @default(now())

  @@index([existent])
}


model Conversation {
  id         Int        @id @default(autoincrement())
  externalId String     @unique @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id])
  
  projectId  String?
  project    Project?   @relation(fields: [projectId], references: [id])

  requests   Request[]

  responses  Response[]
  resources  Resource[] @relation("ConversationResources")
  metadata   Json?
  existent   Boolean?   @default(true)
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([existent])
}



model ResourceTree {
  id         Int      @id @default(autoincrement())
  treeName   String   @db.VarChar(100)
  resourceId Int
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  
  parentId   Int?
  parent     ResourceTree?  @relation("TreeHierarchy", fields: [parentId], references: [id])
  children   ResourceTree[] @relation("TreeHierarchy")

  treeStart  Float
  treeEnd    Float
  depth      Int      @default(0)

  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id])

  deletedAt  DateTime?

  existent   Boolean? @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([treeName, resourceId])
  @@index([treeName, treeStart, treeEnd, existent])
  @@index([existent])
  @@index([deletedAt])
}






model Agent {
  id           String    @id @default(cuid())
  name         String
  scriptId     Int
  script       Script    @relation(fields: [scriptId], references: [id])
  schedule     String    @default("every 10 minutes")
  lastPolledAt DateTime?
  userId       String
  user         User      @relation(fields: [userId], references: [id])

  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id])

  enabled   Boolean  @default(true)

  existent  Boolean? @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  @@unique([name])
  @@index([existent])
}


model UdcLookup {
  uri       String   @id
  notation  String   @unique
  parentUri String?


  title     String

  enLabel   String?
  etLabel   String?
  
  // Nested Set for hierarchical queries
  treeStart Int
  treeEnd   Int
  depth     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  existent  Boolean? @default(true)

  @@index([treeStart, treeEnd, existent])
  @@index([notation, existent])
  @@index([existent])
}

